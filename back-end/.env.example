PORT=8080
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kinmeet

# JWT
JWT_SECRET=your_jwt_secret_here

# Cloudinary (https://console.cloudinary.com/settings/api-keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
REACT_FRONTEND_URL=http://localhost:5173

# Public SPA URL (no trailing slash). Used for FCM web push click links (HTTPS in production).
WEB_APP_URL=http://localhost:5173

# Optional: FCM / Firebase Admin (pick one; path is recommended for local dev — keeps secrets out of env dumps)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk-local.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
