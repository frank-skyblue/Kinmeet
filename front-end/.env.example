# API (optional; default http://localhost:8080/api)
# VITE_API_URL=http://localhost:8080/api

# Local dev only: set to true when you want to test web push (`vite dev`). Omit or leave false to skip permission + FCM registration locally.
# VITE_ENABLE_WEB_PUSH=true

# Firebase Web (FCM) — from Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Firebase / GA4 measurement ID (Analytics) — same Web app config in Firebase Console
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# Web Push certificates (Cloud Messaging → Web configuration)
VITE_FIREBASE_VAPID_KEY=
